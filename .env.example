# Default cleaned dataset used by experiment entry points.
LNAI_DATA_PATH=data/cleaned/aapl-options.parquet

# Cache location for dataset windows, checkpoints, and other artifacts.
LNAI_CACHE_ROOT=cache_inf_forecast

# Raw data directory used by lnai.data.cleaning.
LNAI_RAW_DATA_DIR=data

# Hyperparameter search ranges.
LNAI_HYPERPARAM_PATH=config/hyperparams.yaml

# Reproducibility-friendly Python hash seed.
PYTHONHASHSEED=0
